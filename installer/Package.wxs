<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
      Name="PIFMS Antivirus"
      Manufacturer="PIFMS"
      Version="1.0.0.0"
      UpgradeCode="A5F3D2E0-3A8F-4F1A-9C7E-1F8E1D2C3B4A"
      Scope="perMachine"
      InstallerVersion="500"
      Compressed="yes"
      Codepage="65001">

    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <Feature Id="MainFeature" Title="PIFMS Antivirus" Level="1" AllowAbsent="no">
      <ComponentGroupRef Id="AppComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>

    <SetProperty Id="ProgramDataPath" Value="[CommonAppDataFolder]PIFMS" Before="CostInitialize" Sequence="execute" />

    <CustomAction Id="GrantServiceStartRights"
                  FileRef="PIFMSServiceExe"
                  ExeCommand="/install"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="GrantServiceStartRights" Before="StartServices" Condition="NOT REMOVE" />
    </InstallExecuteSequence>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="PIFMS">
        <Directory Id="ResourcesDir" Name="resources">
          <Directory Id="AvDbDir" Name="avdb" />
        </Directory>
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ShortcutComponents">
      <Component Id="DesktopShortcut" Directory="DesktopFolder" Bitness="always64">
        <RegistryValue
            Root="HKLM"
            Key="Software\PIFMS\Antivirus"
            Name="DesktopShortcut"
            Type="integer"
            Value="1"
            KeyPath="yes" />
        <Shortcut
            Id="PIFMSDesktopShortcut"
            Name="PIFMS"
            Description="PIFMS Antivirus"
            Target="[#PIFMSAppExe]"
            WorkingDirectory="INSTALLFOLDER" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AppComponents">

      <Component Id="ServiceExe" Directory="INSTALLFOLDER" Bitness="always64">
        <File Id="PIFMSServiceExe" Source="$(var.BuildDir)\PIFMSService.exe" KeyPath="yes" />
        <ServiceInstall
            Id="PIFMSServiceInstall"
            Type="ownProcess"
            Name="PIFMSService"
            DisplayName="PIFMS Application Service"
            Description="PIFMS Antivirus background service"
            Start="auto"
            ErrorControl="normal"
            Account="LocalSystem"
            Vital="yes" />
        <ServiceControl
            Id="PIFMSServiceControl"
            Name="PIFMSService"
            Start="install"
            Stop="both"
            Remove="uninstall"
            Wait="yes" />
      </Component>

      <Component Id="AppExe" Directory="INSTALLFOLDER" Bitness="always64">
        <File Id="PIFMSAppExe" Source="$(var.BuildDir)\PIFMSApp.exe" KeyPath="yes" />
      </Component>

      <Component Id="EngineExe" Directory="INSTALLFOLDER" Bitness="always64">
        <File Source="$(var.BuildDir)\PIFMSAntivirusEngine.exe" KeyPath="yes" />
      </Component>

      <Component Id="DefaultDb" Directory="AvDbDir" Bitness="always64">
        <File Source="$(var.SourceDir)\resources\avdb\default.pifmsdb" KeyPath="yes" />
      </Component>

      <Component Id="SigningCert" Directory="AvDbDir" Bitness="always64">
        <File Source="$(var.SourceDir)\resources\avdb\signing.crt" KeyPath="yes" />
      </Component>

      <Component Id="DmitrySigningCert" Directory="AvDbDir" Bitness="always64">
        <File Source="$(var.SourceDir)\resources\avdb\dmitrysigning.crt" KeyPath="yes" />
      </Component>

      <Component Id="ProgramDataCleanup" Directory="INSTALLFOLDER" Bitness="always64">
        <RegistryValue
            Root="HKLM"
            Key="Software\PIFMS\Antivirus"
            Name="ProgramDataCleanup"
            Type="integer"
            Value="1"
            KeyPath="yes" />
        <util:RemoveFolderEx On="uninstall" Property="ProgramDataPath" />
      </Component>

    </ComponentGroup>
  </Fragment>
</Wix>
